// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AI Learning Models
model TradeRecord {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  tokenSymbol     String
  tokenName       String
  tokenMint       String
  action          String   // BUY or SELL
  amount          Float
  entryPrice      Float
  exitPrice       Float?
  exitTimestamp   DateTime?
  outcome         String   @default("PENDING") // WIN, LOSS, PENDING
  profitPercent   Float?
  profit          Float?
  strategy        String
  aiScore         Float    // 0-10
  aiRecommendation String?
  marketCondition  String?
  holdDuration    Int?     // milliseconds
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tokenSymbol])
  @@index([outcome])
  @@index([strategy])
}

model TokenPerformance {
  id              String   @id @default(cuid())
  symbol          String   @unique
  totalTrades     Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  totalProfit     Float    @default(0)
  avgProfitPercent Float   @default(0)
  winRate         Float    @default(0)
  bestTrade       Float    @default(0)
  worstTrade      Float    @default(0)
  avgHoldDuration Int      @default(0)
  isBlacklisted   Boolean  @default(false)
  lastTradeAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([symbol])
  @@index([isBlacklisted])
}

model StrategyPerformance {
  id          String   @id @default(cuid())
  name        String   @unique
  totalTrades Int      @default(0)
  wins        Int      @default(0)
  totalProfit Float    @default(0)
  winRate     Float    @default(0)
  avgProfit   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model TradingPattern {
  id              String   @id @default(cuid())
  aiScoreMin      Int
  aiScoreMax      Int
  timeOfDay       Int      // 0-23 hour
  sentiment       String   @default("NEUTRAL")
  outcome         String   @default("PENDING")
  totalProfit     Float    @default(0)
  occurrenceCount Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([aiScoreMin, aiScoreMax])
  @@index([timeOfDay])
}

model LearningConfig {
  id                      String   @id @default(cuid())
  key                     String   @unique
  value                   String
  description             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}